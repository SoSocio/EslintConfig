{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "declaration": true,
    "outDir": "./dist/lib",
    "strict": true,
    "skipLibCheck": true,
    "noImplicitAny": false,
    "paths": {
      "@sosocio/eslint-config": ["../dist"]
    },
    "typeRoots": ["../node_modules/@types"]
  },
  "include": ["index.ts", "eslint-config.d.ts"]
}
