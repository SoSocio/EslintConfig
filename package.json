{
	"name": "@sosocio/eslint-config",
	"version": "1.1.2",
	"description": "A reusable eslint config",
	"type": "module",
	"main": "dist/index.js",
	"exports": {
		".": {
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts"
		}
	},
	"types": "./dist/index.d.ts",
	"scripts": {
		"test": "echo \"Error: no test specified\" && exit 1",
		"build": "tsc",
		"prepare": "npm run build",
		"prepublishOnly": "npm run build",
		"pub": "npm publish",
		"pack": "npm pack"
	},
	"author": "",
	"license": "ISC",
	"dependencies": {
		"@eslint/js": "^9.34.0",
		"@stylistic/eslint-plugin": "^5.3.1",
		"eslint-plugin-import": "^2.31.0",
		"eslint-plugin-prettier": "^5.2.1",
		"eslint-plugin-promise": "^7.0.0",
		"globals": "^13.24.0",
		"typescript-eslint": "^8.42.0"
	},
	"peerDependencies": {
		"eslint": ">= 8"
	},
	"publishConfig": {
		"registry": "https://npm.pkg.github.com/sosocio"
	},
	"files": [
		"dist",
		"README.md"
	],
	"repository": {
		"type": "git",
		"url": "git://github.com/SoSocio/EslintConfig.git",
		"directory": "@sosocio/eslint-config"
	},
	"devDependencies": {
		"@babel/core": "^7.26.0",
		"@babel/eslint-parser": "^7.25.9",
		"eslint": "^9.34.0",
		"eslint-plugin-json": "^4.0.1",
		"eslint-plugin-json-schema-validator": "^5.1.3",
		"eslint-plugin-jsonc": "^2.18.2",
		"typescript": "^5.3.3"
	}
